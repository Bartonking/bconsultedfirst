rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Leads — server-only write, no client read
    match /leads/{leadId} {
      allow read, write: if false;
    }

    // Audit Jobs — server-only write, clients can read their own job by ID
    match /auditJobs/{jobId} {
      allow read: if true;
      allow write: if false;
    }

    // Audit Reports — server-only write, clients can read their own report by ID
    match /auditReports/{reportId} {
      allow read: if true;
      allow write: if false;
    }

    // Consultations — server-only
    match /consultations/{conId} {
      allow read, write: if false;
    }

    // Audit Engagements — server-only
    match /auditEngagements/{engagementId} {
      allow read, write: if false;
    }

    // Calendly Webhook Logs — server-only
    match /calendlyWebhookLogs/{logId} {
      allow read, write: if false;
    }

    // Raw Calendly Bucket — server-only
    match /calndlybucket/{eventId} {
      allow read, write: if false;
    }

    // Workflow Events — server-only
    match /workflowEvents/{eventId} {
      allow read, write: if false;
    }

    // Event Automation Runs — server-only
    match /eventAutomationRuns/{runId} {
      allow read, write: if false;
    }

    // Event Dead Letters — server-only
    match /eventDeadLetters/{deadLetterId} {
      allow read, write: if false;
    }

    // Service Intake Configs — server-only
    match /serviceIntakeConfigs/{configId} {
      allow read, write: if false;
    }

    // Site Config — server-only
    match /siteConfig/{configId} {
      allow read, write: if false;
    }

    // Contact Messages — server-only
    match /contactMessages/{msgId} {
      allow read, write: if false;
    }
  }
}
